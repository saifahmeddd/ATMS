# Database (PostgreSQL - use Neon, Supabase, or local)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/TMS_DB"

# NextAuth v5 (generate with: npx auth secret or openssl rand -base64 32)
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Session duration in seconds (default 86400 = 24h)
SESSION_MAX_AGE=86400

# SMTP (for password reset emails)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="noreply@almnfthen.com"

# Cron job secret — sent as Authorization: Bearer <secret> header
# Generate with: openssl rand -base64 32
CRON_SECRET=""
